.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 200rpx; /* 给 fixed 操作栏留位 */
}

/* 头部：副标题 + 清空按钮 */
.head {
  position: relative;
  padding: 20rpx 40rpx 32rpx;
}

.head__sub {
  text-align: center;
  font-size: 26rpx;
  letter-spacing: 4rpx;
  color: var(--text-secondary);
}

.head__clear {
  position: absolute;
  right: 32rpx;
  top: 12rpx;
  height: 56rpx;
  padding: 0 24rpx;
  display: inline-flex;
  align-items: center;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: var(--text-secondary);
  background: transparent;
  border: 1rpx solid var(--divider);
  border-radius: 999rpx;
  white-space: nowrap;
  transition: color 0.2s ease, border-color 0.2s ease;
}

.head__clear--touching {
  color: var(--accent);
  border-color: var(--accent);
}

/* 维度区 */
.body {
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.dim {
  background: var(--card);
  border: 1rpx solid var(--divider);
  border-radius: 28rpx;
  box-shadow: var(--sh-card);
  padding: 28rpx;
}

.dim__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.dim__name {
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  color: var(--text);
}

.dim__count {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: var(--text-muted);
}

.dim__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

/* chip */
.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  color: var(--text-secondary);
  background: transparent;
  border: 1rpx solid var(--divider);
  transition: transform 0.15s ease, background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
}

.chip--touching {
  transform: scale(0.96);
}

.chip--on {
  background: var(--accent);
  color: var(--accent-on);
  border-color: transparent;
}

/* 备案 */
.page-icp {
  text-align: center;
  padding: 16rpx 0 0;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: var(--text-muted);
}

/* 底部固定操作栏 */
.footbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg);
  border-top: 1rpx solid var(--divider);
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 20;
}

.footbar__inner {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.footbar__meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.footbar__count {
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  color: var(--text);
  line-height: 1;
}

.footbar__hint {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: var(--text-muted);
  line-height: 1;
}

.footbar__btn {
  flex-shrink: 0;
  height: 88rpx;
  padding: 0 56rpx;
  background: var(--accent);
  color: var(--accent-on);
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.footbar__btn--touching {
  transform: scale(0.97);
  opacity: 0.92;
}

.footbar__btn--disabled {
  background: var(--divider);
  color: var(--text-muted);
}
