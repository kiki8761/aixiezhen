.home {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

/* hero 背景图 */
.home__hero {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* hero 渐变叠加，让标题可读 */
.home__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(180, 200, 210, 0.25) 0%,
    rgba(60, 90, 100, 0.15) 40%,
    rgba(30, 55, 65, 0.55) 100%
  );
  z-index: 1;
}

.home__inner {
  position: relative;
  z-index: 2;
  height: 100%;
  padding: 0 40rpx 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头部 */
.home__head {
  width: 100%;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
  margin-top: 48rpx;
}

.home__logo {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.92;
}

.home__title {
  font-size: 56rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
  color: #FFFFFF;
  text-shadow: 0 4rpx 24rpx rgba(20, 40, 50, 0.4);
  line-height: 1.3;
}

.home__subtitle {
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  letter-spacing: 4rpx;
}

/* 模式卡片 */
.home__cards {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  margin-top: auto;
  margin-bottom: 28rpx;
  padding-top: 48rpx;
}

.mode-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 36rpx 40rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: var(--sh-hero);
  /* 玻璃效果降级：用纯半透明 + 投影模拟 */
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.mode-card--primary {
  background: var(--card-hero-primary);
}

.mode-card--secondary {
  background: var(--card-hero-secondary);
}

.mode-card--touching {
  transform: scale(0.98);
  opacity: 0.9;
}

.mode-card__head {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.mode-card__icon {
  font-size: 44rpx;
  line-height: 1;
}

.mode-card__title {
  font-size: 36rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  color: var(--text);
}

.mode-card__badge {
  margin-left: auto;
  padding: 4rpx 16rpx;
  font-size: 20rpx;
  font-weight: 400;
  letter-spacing: 2rpx;
  color: var(--text-secondary);
  background: var(--divider);
  border-radius: 999rpx;
  line-height: 1.5;
}

.mode-card__desc {
  font-size: 30rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

.mode-card__meta {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 4rpx;
  margin-top: 8rpx;
}

/* 页脚 */
.home__foot {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding-top: 24rpx;
  text-align: center;
}

.home__foot-brand {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1;
}

.home__foot-kiki {
  color: #FFD8A8;
  letter-spacing: 2rpx;
}

.home__foot-icp {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: rgba(255, 255, 255, 0.62);
  line-height: 1;
}

.home__foot-icp--tight {
  margin-top: -14rpx;
}
